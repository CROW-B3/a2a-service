{
  "name": "a2a-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.jsonc --env local",
    "start": "wrangler dev --config wrangler.jsonc --env local",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "deploy:dev": "wrangler deploy --config wrangler.jsonc --env dev",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "bun run prettier src/ --write",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.7",
    "hono": "^4.11.4",
    "uuid": "^11.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.59.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
